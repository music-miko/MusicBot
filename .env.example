# ─────────────────────────────────────────────────────────────
# TeleMusic Bot v1.0.0  —  .env configuration
# Copy to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────

# ── Telegram Bot credentials ──────────────────────────────────
# Get from @BotFather
BOT_TOKEN=1234567890:AAAA_your_bot_token_here

# ── MTProto credentials (for LiveProto / phptgcalls) ─────────
# Get from https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ── Assistant session string ──────────────────────────────────
# Generate with: python3 -c "from pyrogram import Client; Client('s', API_ID, API_HASH).run()"
# or use your phptgcalls session generator
SESSION=BQA...your_pyrogram_session...

# ── Owner Telegram user ID ─────────────────────────────────────
OWNER_ID=603536072

# ── Log channel IDs (optional) ───────────────────────────────
LOGGER_ID=-1001234567890
ERROR_LOG_ID=-1001234567890

# ── API-1 (arc / deadline-tech — YouTube jobs) ────────────────
# Get from https://deadlinetech.site or @smaugxd
API_URL=https://api.arcmusic.fun
API_KEY=your_api1_key_here

# ── API-2 (onegrab — Spotify CDN direct download) ────────────
API_URL2=https://api.onegrab.fun
API_KEY2=your_api2_key_here

# ── Spotify OAuth (fallback metadata) ────────────────────────
# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=6be9f0b34c384ad097cc71b1c1fc5e8b
SPOTIFY_CLIENT_SECRET=2607415f99944cc6b24fa98018fb8c09

# ── MongoDB (optional — for caching) ─────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=telemusic

# ── Bot settings ─────────────────────────────────────────────
DURATION_LIMIT=469
PLAYLIST_FETCH_LIMIT=50

# ── Binary paths (phptgcalls + LiveProto) ─────────────────────
# https://github.com/TakNone/phptgcalls
# https://github.com/TakNone/LiveProto
PHPTGCALLS_BIN=/path/to/bin/phptgcalls
LIVEPROTO_BIN=/path/to/bin/liveproto
