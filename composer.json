{
  "name": "telemusic/bot",
  "description": "Telegram Video Chat Music Streaming Bot (PHP) - v1.0.0",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-mbstring": "*",
    "guzzlehttp/guzzle": "^7.0",
    "mongodb/mongodb": "^1.17",
    "monolog/monolog": "^3.0",
    "vlucas/phpdotenv": "^5.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "TeleMusic\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TeleMusic\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php bot.php"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
